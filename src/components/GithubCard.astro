---
import SocialMedia from "./SocialMedia.astro";
import {contactInfo, isHireable} from "../data/portfolio";
import {fetchGithubProfile} from "../lib/github";

const prof = await fetchGithubProfile();
---

{
  prof ? (
    <div class="main section-animate" id="contact">
      <h2 class="prof-title">Reach Out to me!</h2>
      <div class="row">
        <div class="main-content-profile">
          <div class="blog-header">
            <p class="subTitle blog-subtitle">{contactInfo.subtitle}</p>
          </div>
          {prof.bio && <h2 class="bio-text">"{prof.bio}"</h2>}
          {prof.location !== null && (
            <div class="location-div">
              <span class="desc-prof">
                <svg
                  viewBox="-0.5 -2 20 19"
                  version="1.1"
                  width="22"
                  height="16"
                  aria-hidden="true"
                  stroke="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M6 0C2.69 0 0 2.5 0 5.5 0 10.02 6 16 6 16s6-5.98 6-10.5C12 2.5 9.31 0 6 0zm0 14.55C4.14 12.52 1 8.44 1 5.5 1 3.02 3.25 1 6 1c1.34 0 2.61.48 3.56 1.36.92.86 1.44 1.97 1.44 3.14 0 2.94-3.14 7.02-5 9.05zM8 5.5c0 1.11-.89 2-2 2-1.11 0-2-.89-2-2 0-1.11.89-2 2-2 1.11 0 2 .89 2 2z"
                  />
                </svg>
                {prof.location}
              </span>
            </div>
          )}
          <div class="opp-div">
            <span class="desc-prof">
              Open for opportunities: {isHireable ? "Yes" : "No"}
            </span>
          </div>
          <SocialMedia />
        </div>
        <div class="image-content-profile">
          <img
            src={prof.avatarUrl}
            alt={prof.name + " GitHub avatar"}
            class="profile-image"
            width="200"
            height="200"
            loading="lazy"
            crossorigin="anonymous"
          />
        </div>
      </div>
    </div>
  ) : (
    <div class="main contact-margin-top section-animate" id="contact">
      <div class="contact-div-main">
        <div class="contact-header">
          <h2 class="heading contact-title">{contactInfo.title}</h2>
          <p class="subTitle contact-subtitle">{contactInfo.subtitle}</p>
          <div class="contact-text-div">
            {contactInfo.number && (
              <>
                <a class="contact-detail" href={"tel:" + contactInfo.number}>
                  {contactInfo.number}
                </a>
                <br />
                <br />
              </>
            )}
            <a
              class="contact-detail-email"
              href={"mailto:" + contactInfo.emailAddress}
            >
              {contactInfo.emailAddress}
            </a>
            <br />
            <br />
            <SocialMedia />
          </div>
        </div>
        {/* the old Contact had a .contact-image-div with an email lottie;
            email.json was dropped deliberately, so the column is omitted
            (`.contact-div-main > *` flex still lays out the text block) */}
      </div>
    </div>
  )
}

<style lang="scss">
  @import "../styles/variables";

  /* old global `.main` wrapper folded into the section root */
  .main {
    width: 90%;
    padding: 20px 10px;
    margin: 0px auto;
    margin-top: 4rem;
  }

  /* from old components/githubProfileCard/GithubProfileCard.scss */
  .profile-image {
    border-radius: 50%;
    border: 0.5rem solid $githubProfileCardBorder;
    margin-left: auto;
    width: 100%;
    max-width: 350px;
    height: auto;
    box-shadow: $lightBoxShadow 0 30px 30px -30px;
    transition: all 0.3s ease-out;
  }

  .profile-image:hover {
    box-shadow: none;
  }

  .prof-title {
    margin: 0;
    font-size: 40px;
    font-weight: 400;
  }

  .location-div {
    text-shadow: $githubProfileCardLocationTS;
  }

  .opp-div {
    padding-bottom: 1rem;
  }

  .row {
    display: flex;
  }

  .main-content-profile {
    flex: 80%;
  }

  .image-content-profile {
    text-align: right;
    flex: 20%;
    max-width: 100%;
    height: auto;
  }

  .bio-text {
    line-height: 30px;
    font-size: 22px;
  }

  .desc-prof {
    line-height: 45px;
    font-size: 19px;
  }

  .subTitle {
    color: $subTitle;
  }

  /* .blog-subtitle leaked globally from Blog.scss in the old app; recreated here */
  .blog-subtitle {
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .row {
      display: flex;
      flex-direction: column;
    }

    .main-content-profile {
      text-align: center;
      order: 2;
    }

    .bio-text {
      font-size: 16px;
    }

    .image-content-profile {
      margin-left: auto;
      margin-right: auto;
      order: 1;
    }

    .desc-prof {
      line-height: 30px;
      font-size: 16px;
    }

    .profile-image {
      margin-left: auto;
      margin-right: auto;
      width: 100%;
      max-width: 250px;
      height: auto;
    }

    .profile-image:hover {
      box-shadow: $lightBoxShadow 0 50px 50px -50px;
      transition: 0.3s ease-out;
    }

    .prof-title {
      padding-bottom: 1rem;
      font-size: 32px;
      text-align: center;
    }

    .blog-subtitle {
      font-size: 16px;
      text-align: center;
    }
  }

  /* from old containers/contact/Contact.scss (fallback branch) */
  .contact-div-main {
    display: flex;
  }

  .contact-div-main > * {
    flex: 1;
  }

  .contact-title {
    font-size: 65px;
    font-weight: 400;
    /* pin old h1 UA margin after demotion to h2 (h2 UA would be 0.83em) */
    margin: 0.67em 0;
  }

  .contact-detail,
  .contact-detail-email {
    margin-top: 20px;
    font-size: 40px;
    font-weight: 400;
    color: $subTitle;
    text-decoration: none;
  }

  .contact-detail:hover,
  .contact-detail-email:hover {
    color: $textColor;
    text-shadow: 2px 1px 2px $contactDetailHoverTS;
    transition: all 0.3s;
  }

  .contact-subtitle {
    text-transform: uppercase;
  }

  .contact-text-div {
    margin-top: 1.5rem;
  }

  .contact-margin-top {
    margin-top: 4rem;
  }

  /* old conditional `dark-mode` classes on the subtitle and text div
     (subTitle grey -> white text; `.dark-mode a` link color) */
  :global(html.dark-mode) .contact-subtitle {
    color: white;
  }

  :global(html.dark-mode) .contact-text-div {
    color: white;
  }

  :global(html.dark-mode) .contact-text-div a {
    color: $textColorDark;
  }

  @media (max-width: 1380px), (max-width: 768px) {
    .contact-title {
      font-size: 56px;
      font-weight: 400;
      text-align: center;
    }

    .contact-title {
      font-size: 40px;
      text-align: center;
    }

    .contact-subtitle {
      font-size: 16px;
      line-height: normal;
      text-align: center;
    }

    .contact-text-div {
      text-align: center;
      margin-top: 1.5rem;
    }

    .contact-detail,
    .contact-detail-email {
      font-size: 20px;
    }
  }
</style>
