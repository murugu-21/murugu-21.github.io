---
import {socialMediaLinks} from "../data/portfolio";
import Icon from "./Icon.astro";
---

<div class="social-media-div">
  <a
    href={socialMediaLinks.github}
    class="icon-button github"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="GitHub profile"
  >
    <Icon name="github" />
  </a>
  <a
    href={socialMediaLinks.linkedin}
    class="icon-button linkedin"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="LinkedIn profile"
  >
    <Icon name="linkedin-in" />
  </a>
  <a
    href={`mailto:${socialMediaLinks.gmail}`}
    class="icon-button google"
    aria-label="Send an email"
  >
    <Icon name="envelope" />
  </a>
  <a
    href={socialMediaLinks.twitter}
    class="icon-button twitter"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Twitter profile"
  >
    <Icon name="twitter" />
  </a>
  <a
    href={socialMediaLinks.stackoverflow}
    class="icon-button stack-overflow"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Stack Overflow profile"
  >
    <Icon name="stack-overflow" />
  </a>
</div>

<style lang="scss">
  @import "../styles/variables";

  .social-media-div {
    font-size: 2em;
  }

  .icon-button {
    margin-bottom: 10px;
    text-decoration: none;
    font-size: 0; // collapse stray whitespace text nodes inside the anchor (JSX used to strip them)
  }

  /* the FA <i> was a 2.6rem circle with a 1.3rem glyph (font-size) centered
     via line-height; the inline svg reproduces it with a 1.3rem content box
     (2.6rem outer minus 0.65rem padding on each side) */
  .icon-button :global(svg) {
    color: $textColorDark;
    border-radius: 2.6rem;
    cursor: pointer;
    display: inline-block;
    box-sizing: border-box;
    height: 2.6rem;
    width: 2.6rem;
    padding: 0.65rem;
    margin: 0 5px;
    position: relative;
    user-select: none;
    margin-bottom: 10px;
    vertical-align: middle;
    transition: 0.2s ease-in;
  }

  .linkedin :global(svg) {
    background-color: $linkedin;
  }

  .github :global(svg) {
    background-color: $github;
  }

  .google :global(svg) {
    background-color: $google;
  }

  .twitter :global(svg) {
    background-color: $twitter;
  }

  .stack-overflow :global(svg) {
    background-color: $stackoverflow;
  }

  /* Hover Transition */
  .twitter :global(svg:hover),
  .google :global(svg:hover),
  .github :global(svg:hover),
  .linkedin :global(svg:hover),
  .stack-overflow :global(svg:hover) {
    background-color: $buttonColor; // theme green; was $textColor (#2e353f) which blended into the dark background
  }

  /* Media Query */
  @media (max-width: 768px) {
    .social-media-div {
      text-align: center;
    }
  }
</style>
