---
import {techStack} from "../data/portfolio";
---

<div class="skills-container section-animate">
  <div class="skills-bar">
    <h2 class="skills-heading">Proficiency</h2>
    {
      techStack.experience.map(exp => (
        <div class="skill">
          <p>{exp.stack}</p>
          <div
            class="meter"
            role="meter"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow={parseInt(exp.progressPercentage)}
            aria-label={exp.stack}
          >
            <span style={`width: ${exp.progressPercentage}`} />
          </div>
        </div>
      ))
    }
  </div>
</div>

<style lang="scss">
  @import "../styles/variables";

  .meter {
    height: 20px;
    position: relative;
    background: $progressBarBackground;
    border-radius: 25px;
  }
  .meter > span {
    display: block;
    height: 100%;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
    border-top-left-radius: 20px;
    border-bottom-left-radius: 20px;
    background-color: $progressBarSpanBG;
    position: relative;
    overflow: hidden;
  }
  .skill {
    line-height: 3.5vw;
  }
  .skills-container {
    display: flex;
    width: 90%;
    padding: 20px 10px;
    margin: 0px auto;
    margin-top: 2rem;
  }
  .skills-container > * {
    flex: 1;
    margin-bottom: 30px;
  }
  /* the old build-lottie `.skills-image` column is omitted; above 1456px it
     occupied the right half of the flex row, so cap the bars at 50% there
     to keep the old proportions (below 1456px the old SCSS hid the image
     and the bars already spanned the full row) */
  @media (min-width: 1457px) {
    .skills-bar {
      max-width: 50%;
    }
  }

  /* `.skills-heading` leaked globally from Skills.scss in the old CRA build;
     re-declared here because Astro styles are scoped */
  .skills-heading {
    font-size: 56px;
    font-weight: 400;
    /* pin old h1 UA margin after demotion to h2 (h2 UA would be 0.83em) */
    margin: 0.67em 0;
  }

  /* Media Query */
  @media (max-width: 1456px) {
    .skills-bar {
      line-height: 4rem;
    }
  }

  @media (max-width: 1380px) {
    .skills-heading {
      font-size: 40px;
    }
  }

  @media (max-width: 768px) {
    .skills-container {
      flex-direction: column;
    }
    .skills-bar {
      line-height: 3rem;
      margin: 20px;
    }
    .skills-heading {
      font-size: 30px;
      text-align: center;
    }
  }
</style>
