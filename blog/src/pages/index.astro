---
import BaseLayout from "../layouts/BaseLayout.astro"
import AllPosts from "../components/AllPosts.jsx"
import Bio from "../components/Bio.jsx"
import {
  AUTHOR,
  SOCIAL,
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_URL,
} from "../consts"
import {
  getPublishedPosts,
  postPath,
  formatDate,
  timeToRead,
  excerpt,
} from "../utils/posts"

// Newest first, like the old index page query (sort: date DESC).
const posts = (await getPublishedPosts()).reverse()

// Serializable shape for the AllPosts React island (replaces the page GraphQL
// query). `description` is intentionally left undefined when missing so the
// island's search falls back to the excerpt, same as before.
const serialized = posts.map(post => ({
  href: postPath(post.id),
  title: post.data.title,
  dateFormatted: formatDate(post.data.date),
  minutes: timeToRead(post.body),
  tags: post.data.tags,
  description: post.data.description,
  excerpt: excerpt(post.body),
}))

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: SITE_TITLE,
  description: SITE_DESCRIPTION,
  url: `${SITE_URL}/`,
  author: {
    "@type": "Person",
    name: AUTHOR.name,
    url: `https://twitter.com/${SOCIAL.twitter}`,
  },
}
---

<!-- No title prop: the homepage gets the keyword-rich
     "SDE Journey — <description>" title from BaseHead. -->
<BaseLayout jsonLd={jsonLd}>
  <AllPosts client:load posts={serialized} />
  <Bio client:load author={AUTHOR} social={SOCIAL} />
</BaseLayout>
